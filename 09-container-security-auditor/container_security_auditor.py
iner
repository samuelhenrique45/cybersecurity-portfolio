# ============================================================================
# CONSTANTES E CONFIGURAÇÃO
# ============================================================================

class Severity(Enum):
    CRITICAL = "CRITICAL"
    HIGH = "HIGH"
    MEDIUM = "MEDIUM"
    LOW = "LOW"
    INFO = "INFO"

    def color(self):
        colors = {
            "CRITICAL": "\033[91m",  # Red
            "HIGH": "\033[95m",      # Purple
            "MEDIUM": "\033[93m",    # Yellow
            "LOW": "\033[94m",       # Blue
            "INFO": "\033[92m"       # Green
        }
        return colors.get(self.value, "\033[0m")


@dataclass
class Finding:
    """Estrutura para armazenar achados de segurança"""
    title: str
    description: str
    severity: Severity
    remediation: str
    cve_id: str = None
    reference: str = None
    
    def to_dict(self) -> dict:
        return {
            "title": self.title,
            "description": self.description,
            "severity": self.severity.value,
            "remediation": self.remediation,
            "cve_id": self.cve_id,
            "reference": self.reference
        }


@dataclass
class ContainerAuditResult:
    """Resultado da auditoria de um container"""
    container_id: str
    container_name: str
    image: str
    status: str
    findings: List[Finding] = field(default_factory=list)
    score: int = 100
    timestamp: str = field(default_factory=lambda: datetime.now().isoformat())


# ============================================================================
# VERIFICAÇÕES DE SEGURANÇA - CIS BENCHMARKS PARA DOCKER
# ============================================================================

class ContainerSecurityAuditor:
    """Auditor de segurança para containers Docker"""
    
    def __init__(self):
        self.results: List[ContainerAuditResult] = []
        self.global_findings: List[Finding] = []
        self.docker_available = self._check_docker()
    
    def _check_docker(self) -> bool:
        """Verifica se Docker está disponível"""
        try:
            result = subprocess.run(
                ["docker", "version", "--format", "{{.Server.Version}}"],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                print(f"[+] Docker disponível: v{result.stdout.strip()}")
                return True
        except FileNotFoundError:
            print("[-] Docker não encontrado no sistema")
        return False
    
    def _run_docker_command(self, cmd: List[str]) -> Tuple[str, str, int]:
        """Executa comando docker e retorna (stdout, stderr, returncode)"""
        try:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
            return result.stdout, result.stderr, result.returncode
        except subprocess.TimeoutExpired:
            return "", "Timeout", -1
        except Exception as e:
            return "", str(e), -1
    
    def _get_running_containers(self) -> List[Dict]:
        """Obtém lista de containers em execução"""
        stdout, _, _ = self._run_docker_command(
            ["docker", "ps", "--format", "json"]
        )
        
        containers = []
        for line in stdout.strip().split('\n'):
            if line:
                try:
                    containers.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        
        # Fallback para formato antigo
        if not containers:
            stdout, _, _ = self._run_docker_command(
                ["docker", "ps", "--format", "table {{.ID}}\t{{.Names}}\t{{.Image}}\t{{.Status}}"]
            )
            lines = stdout.strip().split('\n')[1:]  # Skip header
            for line in lines:
                parts = line.split('\t')
                if len(parts) >= 4:
                    containers.append({
                        "ID": parts[0],
                        "Names": parts[1],
                        "Image": parts[2],
                        "Status": parts[3]
                    })
        
        return containers
    
    def _get_all_containers(self) -> List[Dict]:
        """Obtém lista de todos os containers (incluindo parados)"""
        stdout, _, _ = self._run_docker_command(
            ["docker", "ps", "-a", "--format", "json"]
        )
        
        containers = []
        for line in stdout.strip().split('\n'):
            if line:
                try:
                    containers.append(json.loads(line))
                except json.JSONDecodeError:
                    continue
        return containers
    
    def _get_container_details(self, container_id: str) -> Dict:
        """Obtém detalhes de um container específico"""
        stdout, _, _ = self._run_docker_command(
            ["docker", "inspect", container_id]
        )
        try:
            data = json.loads(stdout)
            if data:
                return data[0]
        except json.JSONDecodeError:
            pass
        return {}
    
    def _get_image_vulnerabilities(self, image_name: str) -> List[Finding]:
        """Verifica vulnerabilidades conhecidas na imagem usando grype/trivy"""
        findings = []
        
        # Tentar usar Trivy primeiro
        trivy_found = self._scan_with_trivy(image_name)
        if trivy_found:
            return trivy_found
        
        # Tentar usar Grype como fallback
        grype_found = self._scan_with_grype(image_name)
        if grype_found:
            return grype_found
        
        # Se nenhum scanner disponível, usar verificação básica
        findings.append(Finding(
            title="Scanner de Vulnerabilidades Não Disponível",
            description="Trivy ou Grype não encontrados. Instale para análise completa de CVEs.",
            severity=Severity.INFO,
            remediation="Instale trivy (https://aquasecurity.github.io/trivy) ou grype (https://github.com/anchore/grype)"
        ))
        
        return findings
    
    def _scan_with_trivy(self, image_name: str) -> List[Finding]:
        """Escaneia imagem com Trivy"""
        findings = []
        
        # Verificar se trivy está instalado
        try:
            subprocess.run(["trivy", "--version"], capture_output=True, check=False)
        except FileNotFoundError:
            return []
        
        print(f"    Escaneando {image_name} com Trivy...")
        
        # Pull da imagem se necessário
        self._run_docker_command(["docker", "pull", image_name])
        
        # Executar trivy
        stdout, stderr, rc = self._run_docker_command(
            ["trivy", "image", "--format", "json", "--severity", "CRITICAL,HIGH", image_name]
        )
        
        if rc != 0:
            return []
        
        try:
            data = json.loads(stdout)
            for result in data.get("Results", []):
                for vuln in result.get("Vulnerabilities", []):
                    severity_str = vuln.get("Severity", "MEDIUM")
                    severity = self._map_severity(severity_str)
                    
                    findings.append(Finding(
                        title=f"CVE: {vuln.get('VulnerabilityID', 'Unknown')}",
                        description=f"{vuln.get('Title', vuln.get('Description', ''))}\n"
                                   f"Pacote: {vuln.get('PkgName', 'Unknown')} v{vuln.get('InstalledVersion', '')}",
                        severity=severity,
                        remediation=f"Atualizar para: {vuln.get('FixedVersion', 'versão mais recente')}",
                        cve_id=vuln.get('VulnerabilityID'),
                        reference=vuln.get('PrimaryURL')
                    ))
        except json.JSONDecodeError:
            pass
        
        return findings
    
    def _scan_with_grype(self, image_name: str) -> List[Finding]:
        """Escaneia imagem com Grype"""
        findings = []
        
        try:
            subprocess.run(["grype", "--version"], capture_output=True, check=False)
        except FileNotFoundError:
            return []
        
        print(f"    Escaneando {image_name} com Grype...")
        
        stdout, _, rc = self._run_docker_command(
            ["grype", image_name, "-o", "json"]
        )
        
        if rc != 0:
            return []
        
        try:
            data = json.loads(stdout)
            for match in data.get("matches", []):
                vuln = match.get("vulnerability", {})
                artifact = match.get("artifact", {})
                
                severity_str = vuln.get("severity", "MEDIUM")
                severity = self._map_severity(severity_str)
                
                findings.append(Finding(
                    title=f"CVE: {vuln.get('id', 'Unknown')}",
                    description=f"{vuln.get('description', '')[:200]}\n"
                               f"Pacote: {artifact.get('name', 'Unknown')} v{artifact.get('version', '')}",
                    severity=severity,
                    remediation=vuln.get('fix', {}).get('versions', ['atualizar'])[0],
                    cve_id=vuln.get('id'),
                    reference=vuln.get('urls', [''])[0] if vuln.get('urls') else None
                ))
        except json.JSONDecodeError:
            pass
        
        return findings
    
    def _map_severity(self, severity_str: str) -> Severity:
        """Mapeia string de severidade para enum"""
        severity_map = {
            "CRITICAL": Severity.CRITICAL,
            "HIGH": Severity.HIGH,
            "MEDIUM": Severity.MEDIUM,
            "LOW": Severity.LOW,
            "INFO": Severity.INFO
        }
        return severity_map.get(severity_str.upper(), Severity.MEDIUM)
    
    # ========================================================================
    # VERIFICAÇÕES DE CONFIGURAÇÃO DO CONTAINER
    # ========================================================================
    
    def check_privileged_mode(self, details: Dict) -> Optional[Finding]:
        """Verifica se container está rodando em modo privilegiado"""
        host_config = details.get("HostConfig", {})
        if host_config.get("Privileged", False):
            return Finding(
                title="Container em Modo Privilegiado",
                description="O container está rodando com --privileged, o que lhe dá acesso a todos os dispositivos do host.",
                severity=Severity.CRITICAL,
                remediation="Remova o flag --privileged e adicione apenas as capacidades necessárias com --cap-add"
            )
        return None
    
    def check_root_user(self, details: Dict) -> Optional[Finding]:
        """Verifica se container roda como root"""
        config = details.get("Config", {})
        user = config.get("User", "")
        
        if not user or user == "" or user == "0" or user == "root":
            return Finding(
                title="Container Rodando como Root",
                description="O container está executando como usuário root. Isso pode permitir escalonamento de privilégios.",
                severity=Severity.HIGH,
                remediation="Crie um usuário não-root no Dockerfile e use 'USER <user>' ou execute com '--user <UID>'"
            )
        return None
    
    def check_host_network(self, details: Dict) -> Optional[Finding]:
        """Verifica se container usa rede do host"""
        host_config = details.get("HostConfig", {})
        network_mode = host_config.get("NetworkMode", "")
        
        if network_mode == "host":
            return Finding(
                title="Container Usando Rede do Host",
                description="O container está usando --network host, compartilhando a pilha de rede do host.",
                severity=Severity.MEDIUM,
                remediation="Use redes bridge isoladas ou user-defined networks para isolar o container"
            )
        return None
    
    def check_host_pid(self, details: Dict) -> Optional[Finding]:
        """Verifica se container compartilha PID namespace"""
        host_config = details.get("HostConfig", {})
        pid_mode = host_config.get("PidMode", "")
        
        if pid_mode == "host":
            return Finding(
                title="Container Compartilha PID Namespace do Host",
                description="O container pode ver e interagir com processos do host via --pid=host.",
                severity=Severity.HIGH,
                remediation="Remova o flag --pid=host para isolar o namespace de processos"
            )
        return None
    
    def check_readonly_rootfs(self, details: Dict) -> Optional[Finding]:
        """Verifica se root filesystem é read-only"""
        host_config = details.get("HostConfig", {})
        readonly = host_config.get("ReadonlyRootfs", False)
        
        if not readonly:
            return Finding(
                title="Root Filesystem Permissivo",
                description="O sistema de arquivos raiz é gravável. Malware pode persistir alterações.",
                severity=Severity.MEDIUM,
                remediation="Execute o container com '--read-only' e use volumes para dados que precisam ser escritos"
            )
        return None
    
    def check_resource_limits(self, details: Dict) -> Optional[Finding]:
        """Verifica se limites de recursos estão configurados"""
        host_config = details.get("HostConfig", {})
        memory_limit = host_config.get("Memory", 0)
        cpu_shares = host_config.get("CpuShares", 0)
        
        issues = []
        if memory_limit == 0:
            issues.append("sem limite de memória")
        if cpu_shares == 0:
            issues.append("sem limite de CPU")
        
        if issues:
            return Finding(
                title="Limites de Recursos Não Configurados",
                description=f"Container sem restrições: {', '.join(issues)}. Pode causar DoS no host.",
                severity=Severity.MEDIUM,
                remediation="Use '--memory' e '--cpus' para limitar recursos do container"
            )
        return None
    
    def check_docker_socket_mount(self, details: Dict) -> Optional[Finding]:
        """Verifica se docker.sock está montado"""
        mounts = details.get("Mounts", [])
        for mount in mounts:
            if "/var/run/docker.sock" in mount.get("Source", ""):
                return Finding(
                    title="Docker Socket Montado no Container",
                    description="O socket do Docker está montado. O container pode controlar o daemon Docker do host.",
                    severity=Severity.CRITICAL,
                    remediation="Remova a montagem de /var/run/docker.sock a menos que absolutamente necessário"
                )
        return None
    
    def check_sensitive_mounts(self, details: Dict) -> List[Finding]:
        """Verifica montagens sensíveis"""
        findings = []
        sensitive_paths = [
            "/etc/shadow", "/etc/passwd", "/etc/ssh", "/root/.ssh",
            "/var/lib/docker", "/proc", "/sys", "/etc/kubernetes"
        ]
        
        mounts = details.get("Mounts", [])
        for mount in mounts:
            source = mount.get("Source", "")
            for sensitive in sensitive_paths:
                if sensitive in source:
                    findings.append(Finding(
                        title="Montagem de Diretório Sensível",
                        description=f"O diretório sensível '{source}' está montado no container.",
                        severity=Severity.HIGH,
                        remediation="Evite montar diretórios do sistema ou use bind mounts com permissões restritas"
                    ))
                    break
        
        return findings
    
    def check_environment_secrets(self, details: Dict) -> List[Finding]:
        """Verifica variáveis de ambiente com secrets"""
        findings = []
        secret_patterns = [
            (r'(?i)passw(or)?d', "senha"),
            (r'(?i)secret', "secret"),
            (r'(?i)token', "token"),
            (r'(?i)key', "chave"),
            (r'(?i)api[_-]?key', "API key"),
            (r'(?i)auth', "autenticação"),
            (r'[A-Za-z0-9+/]{40,}', "possível token longo"),
        ]
        
        config = details.get("Config", {})
        env_vars = config.get("Env", [])
        
        for env in env_vars:
            for pattern, description in secret_patterns:
                if re.search(pattern, env):
                    # Ofuscar o valor
                    parts = env.split('=', 1)
                    if len(parts) == 2:
                        name, value = parts
                        if len(value) > 10:
                            value = value[:6] + "..." + value[-4:]
                        display_env = f"{name}={value}"
                    else:
                        display_env = env
                    
                    findings.append(Finding(
                        title="Secret Exposto em Variável de Ambiente",
                        description=f"Possível {description} encontrado em env: {display_env}",
                        severity=Severity.HIGH,
                        remediation="Use Docker secrets (Swarm) ou volumes com secrets em vez de variáveis de ambiente"
                    ))
                    break
        
        return findings
    
    def check_healthcheck(self, details: Dict) -> Optional[Finding]:
        """Verifica se container tem healthcheck configurado"""
        config = details.get("Config", {})
        healthcheck = config.get("Healthcheck", {})
        
        if not healthcheck or not healthcheck.get("Test"):
            return Finding(
                title="Healthcheck Não Configurado",
                description="O container não possui healthcheck configurado.",
                severity=Severity.LOW,
                remediation="Adicione HEALTHCHECK no Dockerfile ou use '--health-cmd' no docker run"
            )
        return None
    
    def check_label_metadata(self, details: Dict) -> Optional[Finding]:
        """Verifica se container tem labels de metadados"""
        config = details.get("Config", {})
        labels = config.get("Labels", {})
        
        required_labels = ["maintainer", "version", "description"]
        missing = [label for label in required_labels if label not in labels]
        
        if missing:
            return Finding(
                title="Metadados Faltando",
                description=f"Labels recomendadas ausentes: {', '.join(missing)}",
                severity=Severity.INFO,
                remediation=f"Adicione LABEL {' '.join(missing)} no Dockerfile"
            )
        return None
    
