class DockerDaemonAuditor:
    """Audita a configuração do daemon Docker"""
    
    def __init__(self):
        self.findings: List[Finding] = []
    
    def check_daemon_config(self) -> List[Finding]:
        """Verifica configuração do daemon Docker"""
        findings = []
        
        # Verificar se Docker socket está exposto
        docker_socket = "/var/run/docker.sock"
        if os.path.exists(docker_socket):
            socket_perms = oct(os.stat(docker_socket).st_mode)[-3:]
            if socket_perms != "660":
                findings.append(Finding(
                    title="Permissões Incorretas no Docker Socket",
                    description=f"Socket Docker tem permissões {socket_perms}. Deveria ser 660.",
                    severity=Severity.HIGH,
                    remediation="sudo chmod 660 /var/run/docker.sock && sudo chown root:docker /var/run/docker.sock"
                ))
        
        # Verificar configuração do daemon
        daemon_config_paths = [
            "/etc/docker/daemon.json",
            "/etc/docker/daemon.yaml"
        ]
        
        for config_path in daemon_config_paths:
            if os.path.exists(config_path):
                try:
                    with open(config_path, 'r') as f:
                        if config_path.endswith('.json'):
                            config = json.load(f)
                            
                            # Verificar se live-restore está ativado
                            if config.get("live-restore", False):
                                findings.append(Finding(
                                    title="Live Restore Ativado",
                                    description="live-restore mantém containers rodando quando daemon para.",
                                    severity=Severity.INFO,
                                    remediation="Considere desativar em ambientes críticos"
                                ))
                            
                            # Verificar se iptables está ativado
                            if not config.get("iptables", True):
                                findings.append(Finding(
                                    title="iptables Desativado",
                                    description="Docker não gerencia regras iptables automaticamente.",
                                    severity=Severity.MEDIUM,
                                    remediation="Ative iptables no daemon.json"
                                ))
                except:
                    pass
        
        return findings
    
    def check_docker_version(self) -> Optional[Finding]:
        """Verifica versão do Docker"""
        try:
            result = subprocess.run(
                ["docker", "version", "--format", "{{.Server.Version}}"],
                capture_output=True, text=True
            )
            version = result.stdout.strip()
            
            # Verificar se versão é antiga
            if version:
                major, minor = version.split('.')[:2]
                if int(major) < 20 or (int(major) == 20 and int(minor) < 10):
                    return Finding(
                        title=f"Versão do Docker Desatualizada",
                        description=f"Docker v{version} pode ter vulnerabilidades conhecidas.",
                        severity=Severity.MEDIUM,
                        remediation="Atualize para a versão mais recente do Docker Engine"
                    )
        except:
            pass
        
        return None


