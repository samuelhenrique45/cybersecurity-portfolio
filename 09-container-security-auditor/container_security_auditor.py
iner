                        remediation="Publique portas apenas em localhost (127.0.0.1) quando possível"
                    ))
        
        return findings
    
    def check_capabilities(self, details: Dict) -> List[Finding]:
        """Verifica capacidades Linux do container"""
        findings = []
        host_config = details.get("HostConfig", {})
        
        # Capacidades perigosas
        dangerous_caps = [
            "CAP_SYS_ADMIN", "CAP_SYS_RAWIO", "CAP_SYS_PTRACE",
            "CAP_NET_ADMIN", "CAP_NET_RAW", "CAP_DAC_OVERRIDE",
            "CAP_DAC_READ_SEARCH", "CAP_SYS_MODULE", "CAP_SYSLOG"
        ]
        
        cap_add = host_config.get("CapAdd", [])
        cap_drop = host_config.get("CapDrop", [])
        
        for cap in dangerous_caps:
            if cap in cap_add:
                findings.append(Finding(
                    title=f"Capacidade Perigosa Adicionada: {cap}",
                    description=f"O container tem a capacidade {cap} adicionada, o que pode permitir escalonamento.",
                    severity=Severity.HIGH,
                    remediation=f"Remova --cap-add={cap} e adicione apenas capacidades estritamente necessárias"
                ))
        
        # Verificar se todas as capacidades foram dropadas
        if "ALL" not in cap_drop:
            findings.append(Finding(
                title="Capacidades Não Limitadas",
                description="O container mantém capacidades Linux padrão. Drop capacidades desnecessárias.",
                severity=Severity.MEDIUM,
                remediation="Execute com '--cap-drop=ALL' e adicione apenas as necessárias com '--cap-add'"
            ))
        
        return findings
    
    def check_seccomp_profile(self, details: Dict) -> Optional[Finding]:
        """Verifica perfil seccomp"""
        host_config = details.get("HostConfig", {})
        security_opt = host_config.get("SecurityOpt", [])
        
        has_seccomp = any("seccomp" in opt for opt in security_opt)
        
        if not has_seccomp:
            return Finding(
                title="Perfil Seccomp Não Configurado",
                description="O container não tem perfil seccomp personalizado.",
                severity=Severity.LOW,
                remediation="Use '--security-opt seccomp=/path/to/profile.json' ou o perfil padrão do Docker"
            )
        return None
    
    def check_apparmor_profile(self, details: Dict) -> Optional[Finding]:
        """Verifica perfil AppArmor"""
        host_config = details.get("HostConfig", {})
        security_opt = host_config.get("SecurityOpt", [])
        
        has_apparmor = any("apparmor" in opt for opt in security_opt)
        
        if not has_apparmor:
            return Finding(
                title="Perfil AppArmor Não Configurado",
                description="O container não tem perfil AppArmor.",
                severity=Severity.LOW,
                remediation="Use '--security-opt apparmor=profile-name' para restringir ainda mais"
            )
        return None
    
    def check_no_new_privileges(self, details: Dict) -> Optional[Finding]:
        """Verifica flag no-new-privileges"""
        host_config = details.get("HostConfig", {})
        security_opt = host_config.get("SecurityOpt", [])
        
        has_nnp = any("no-new-privileges" in opt for opt in security_opt)
        
        if not has_nnp:
            return Finding(
                title="No New Privileges Não Ativado",
                description="Processos no container podem ganhar novos privilégios via setuid/binários.",
                severity=Severity.MEDIUM,
                remediation="Execute com '--security-opt=no-new-privileges' para prevenir escalonamento"
            )
        return None
    
    def check_container_liveness(self, container_id: str, status: str) -> Optional[Finding]:
        """Verifica se container está saudável"""
        if "unhealthy" in status.lower():
            return Finding(
                title="Container Não Saudável",
                description=f"O container está em estado: {status}",
                severity=Severity.MEDIUM,
                remediation=f"Verifique logs do container: docker logs {container_id}"
            )
        return None
    
    def check_restart_policy(self, details: Dict) -> Optional[Finding]:
        """Verifica política de restart"""
        host_config = details.get("HostConfig", {})
        restart_policy = host_config.get("RestartPolicy", {})
        
        name = restart_policy.get("Name", "")
        
        if name == "always":
            return Finding(
                title="Política de Restart Sempre",
                description="Container restart policy 'always' pode esconder falhas.",
                severity=Severity.LOW,
                remediation="Use 'unless-stopped' ou 'on-failure' com limites"
            )
        return None
    
    def audit_container(self, container: Dict) -> ContainerAuditResult:
        """Audita um único container"""
        container_id = container.get("ID", "")
        container_name = container.get("Names", "").lstrip('/')
        image = container.get("Image", "")
        status = container.get("Status", "")
        
        print(f"\n[+] Auditando container: {container_name} ({container_id[:12]})")
        
        result = ContainerAuditResult(
            container_id=container_id,
            container_name=container_name,
            image=image,
            status=status
        )
        
        # Obter detalhes completos
        details = self._get_container_details(container_id)
        if not details:
            result.findings.append(Finding(
                title="Não foi possível obter detalhes",
                description="Falha ao inspecionar o container",
                severity=Severity.INFO,
                remediation="Verifique permissões do Docker"
            ))
            return result
        
        # Executar verificações
        checks = [
            self.check_privileged_mode(details),
            self.check_root_user(details),
            self.check_host_network(details),
            self.check_host_pid(details),
            self.check_readonly_rootfs(details),
            self.check_resource_limits(details),
            self.check_docker_socket_mount(details),
            self.check_healthcheck(details),
            self.check_restart_policy(details),
            self.check_no_new_privileges(details),
        ]
        
        for check in checks:
            if check:
                result.findings.append(check)
        
        # Verificações que retornam listas
        result.findings.extend(self.check_sensitive_mounts(details))
        result.findings.extend(self.check_environment_secrets(details))
        result.findings.extend(self.check_exposed_ports(details))
        result.findings.extend(self.check_capabilities(details))
        
        # Verificações opcionais
        seccomp = self.check_seccomp_profile(details)
        if seccomp:
            result.findings.append(seccomp)
        
        apparmor = self.check_apparmor_profile(details)
        if apparmor:
            result.findings.append(apparmor)
        
        liveness = self.check_container_liveness(container_id, status)
        if liveness:
            result.findings.append(liveness)
        
        # Calcular score (100 - penalidades)
        severity_weights = {
            Severity.CRITICAL: 30,
            Severity.HIGH: 20,
            Severity.MEDIUM: 10,
            Severity.LOW: 5,
            Severity.INFO: 0
        }
        
        penalty = sum(severity_weights[f.severity] for f in result.findings)
        result.score = max(0, 100 - penalty)
        
        return result
    
    def audit_all_containers(self) -> List[ContainerAuditResult]:
        """Audita todos os containers em execução"""
        if not self.docker_available:
            print("[-] Docker não disponível")
            return []
        
        containers = self._get_running_containers()
        
        if not containers:
            print("[-] Nenhum container em execução encontrado")
            return []
        
        print(f"\n[+] Encontrados {len(containers)} containers em execução")
        
        results = []
        for container in containers:
            result = self.audit_container(container)
            results.append(result)
        
        self.results = results
        return results
    
    def audit_specific_container(self, container_id_or_name: str) -> Optional[ContainerAuditResult]:
        """Audita um container específico pelo ID ou nome"""
        if not self.docker_available:
            print("[-] Docker não disponível")
            return None
        
        # Buscar container
        containers = self._get_all_containers()
        target = None
        
        for c in containers:
            if c.get("ID", "").startswith(container_id_or_name) or c.get("Names", "").lstrip('/') == container_id_or_name:
                target = c
                break
        
        if not target:
            print(f"[-] Container não encontrado: {container_id_or_name}")
            return None
        
        return self.audit_container(target)


