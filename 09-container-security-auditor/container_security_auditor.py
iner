                if len(parts) >= 1 and parts[0] and parts[0] != "<none>":
                    images.append(parts[0])
                    print(f"  [{i}] {parts[0]} ({parts[1] if len(parts) > 1 else 'N/A'})")
        
        if images:
            choice = input("\nNúmero da imagem ou nome: ").strip()
            if choice.isdigit() and 1 <= int(choice) <= len(images):
                image_name = images[int(choice) - 1]
            else:
                image_name = choice
            
            findings = image_auditor.audit_image(image_name)
            
            if findings:
                print(f"\n📋 Achados para {image_name}:")
                for finding in findings:
                    print(f"\n  [{finding.severity.value}] {finding.title}")
                    print(f"    {finding.description[:200]}")
                    print(f"    → {finding.remediation}")
            else:
                print(f"\n✅ Nenhum achado significativo para {image_name}")
    
    elif op == "4":
        print("\n🔍 Verificando configuração do Docker Daemon...")
        daemon_auditor = DockerDaemonAuditor()
        
        findings = daemon_auditor.check_daemon_config()
        version_finding = daemon_auditor.check_docker_version()
        if version_finding:
            findings.append(version_finding)
        
        if findings:
